<head>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">

  <style>
    /* 1. Override Pico CSS defaults with your Periwinkle Palette */
    :root {
      --pico-font-family-sans-serif: Verdana, sans-serif;
      --pico-background-color: #f0e6ff;
      --pico-color: #9d84b7;
      --pico-primary: #c8b6ff;
      --pico-primary-hover: #9d84b7;
    }

    body {
      background-color: #f0e6ff;
      padding: 2rem 1rem;
      max-width: 700px;
      /* Slightly narrower than the index page for a better reading experience */
      margin: 0 auto;
    }

    /* 2. Notice Message */
    .periwinkle-notice {
      background-color: #e6d9f0;
      color: #9d84b7;
      padding: 1rem;
      border-radius: 10px;
      border: 2px solid #d4c5ff;
      text-align: center;
      font-weight: bold;
      margin-bottom: 2rem;
      box-shadow: 0 4px 10px rgba(157, 132, 183, 0.1);
    }

    /* 3. The Main Content Card */
    .show-card {
      background: #ffffff;
      border: 2px solid #e6d9f0;
      border-radius: 15px;
      padding: 2.5rem;
      box-shadow: 0 8px 20px rgba(157, 132, 183, 0.08);
      margin-bottom: 2rem;
    }

    /* 4. Action Buttons Container */
    .actions-container {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
      /* Ensures buttons stack nicely on tiny mobile screens */
    }

    /* Rails button_to generates a form, which can mess up flexbox alignment. This fixes it. */
    .actions-container form {
      margin: 0;
    }

    /* 5. Custom Delete Button Hover State */
    .btn-delete {
      --pico-primary: #9d84b7;
      /* Dark periwinkle default */
      --pico-primary-hover: #ff8a8a;
      /* Turns a soft red on hover to warn the user */
    }
  </style>
</head>

<%# Only render the notice if there is one %>
  <% if notice.present? %>
    <p class="periwinkle-notice">
      <%= notice %>
    </p>
    <% end %>

      <div class="show-card">
        <%= render @person %>
      </div>

      <div class="actions-container">
        <%# Standard primary button for Edit %>
          <%= link_to "Edit this person" , edit_person_path(@person), role: "button" %>

            <%# Outline button for Back so it doesn't compete visually with Edit %>
              <%= link_to "Back to people" , people_path, role: "button" , class: "outline" %>

                <%# Custom styling for Destroy %>
                  <%= button_to "Destroy this person" , @person, method: :delete, class: "btn-delete outline" %>
      </div>