<div id="<%= dom_id person %>">
  <div>
    <strong>Name:</strong>
    <%= person.name %>
  </div>

  <div>
    <strong>First name:</strong>
    <%= person.first_name %>
  </div>

  <div>
    <strong>Last name:</strong>
    <%= person.last_name %>
  </div>

  <div>
    <strong>Id number:</strong>
    <%= person.id_number %>
  </div>

</div>
